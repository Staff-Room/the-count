# Plaid API Configuration
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_secret_here
# sandbox (fake data) | production (real data; request Trial in Plaid Dashboard first)
PLAID_ENVIRONMENT=sandbox
PLAID_VERSION=2020-09-14

# Optional: Plaid webhooks (only if you expose a public URL; not required for local sync)
# PLAID_WEBHOOK_URL=https://your-tunnel.example.com/plaid/webhook

# Local SQLite (default: src/backend/data/thecount.db)
# THE_COUNT_DB_PATH=/path/to/thecount.db

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True