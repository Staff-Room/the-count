# Plaid API Configuration
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_secret_here
# sandbox (fake data) | production (real data; request Trial in Plaid Dashboard first)
PLAID_ENVIRONMENT=sandbox
PLAID_VERSION=2020-09-14

# Optional: Plaid webhooks (only if you expose a public URL; not required for local sync)
# PLAID_WEBHOOK_URL=https://your-tunnel.example.com/plaid/webhook

# Local SQLite (default: src/backend/data/thecount.db)
# THE_COUNT_DB_PATH=/path/to/thecount.db

# Optional: keep Notion worker in sync when /api/sync_transactions runs
# Set to false to disable worker updates from the dashboard sync button.
# NOTION_WORKER_AUTO_SYNC=true
# Optional path override (default: ./notion-worker)
# NOTION_WORKER_DIR=/absolute/path/to/the-count/notion-worker
# Optional sync key overrides
# NOTION_WORKER_ACCOUNTS_SYNC_KEY=plaidAccountsSync
# NOTION_WORKER_TRANSACTIONS_SYNC_KEY=plaidTransactionsSync

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
