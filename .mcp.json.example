{
  "mcpServers": {
    "thecount": {
      "command": "/absolute/path/to/the-count/venv/bin/python",
      "args": ["/absolute/path/to/the-count/src/mcp/server.py"],
      "env": {
        "PLAID_CLIENT_ID": "your-plaid-client-id",
        "PLAID_SECRET": "your-plaid-secret",
        "PLAID_ENVIRONMENT": "development"
      }
    }
  }
}
